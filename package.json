{
  "name": "matthew-bramer-blog",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "css:build": "tailwindcss -i ./src/assets/styles.css -o ./dist/assets/styles.css --postcss --minify",
    "css:watch": "tailwindcss -i ./src/assets/styles.css -o ./dist/assets/styles.css --postcss --watch",
    "prebuild": "tsx scripts/generate-embeddings.ts && vite build",
    "build": "npm run prebuild && eleventy && npm run css:build",
    "dev": "npm run prebuild && npm run css:build && concurrently \"vite build --watch\" \"npm run css:watch\" \"eleventy --serve\""
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "@11ty/eleventy-plugin-rss": "^2.0.4",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@vitejs/plugin-react": "^5.0.2",
    "@vitejs/plugin-vue": "^6.0.1",
    "@types/node": "^20.0.0",
    "concurrently": "^9.2.1",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^7.3.2",
    "vue": "^3.5.22",
    "tailwindcss": "^3.4.0",
    "postcss": "^8.4.0",
    "autoprefixer": "^10.4.0"
  },
  "dependencies": {
    "@xenova/transformers": "^2.6.0",
    "gray-matter": "^4.0.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "svelte": "^5.38.6"
  }
}